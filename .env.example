# ============================================================
# Variables d'environnement — Mothome
# Copier ce fichier en .env.local pour le développement local
# ============================================================

# ----------------------------
# Resend (envoi d'emails)
# ----------------------------
# Clé API Resend : https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email destinataire des notifications (formulaires de contact, devis, RDV)
CONTACT_EMAIL_TO=contact@mothome.fr

# Email expéditeur (doit être un domaine vérifié dans Resend)
CONTACT_EMAIL_FROM=noreply@mothome.fr

# ----------------------------
# Site (utilisé par next-sitemap)
# ----------------------------
SITE_URL=https://www.mothome.fr

# ----------------------------
# Analytics (optionnel)
# Vercel Analytics est activé via le dashboard Vercel, pas besoin de variable ici.
# Speed Insights est également activé via le dashboard.
# ----------------------------
