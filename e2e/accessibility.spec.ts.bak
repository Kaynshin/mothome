import { test, expect } from "@playwright/test";
import { injectAxe, checkA11y } from "@axe-core/playwright";

/**
 * Accessibility Audit Tests — WCAG AA Compliance
 *
 * Tests all pages for:
 * - Automated accessibility violations (axe-core)
 * - Keyboard navigation
 * - Color contrast
 * - ARIA attributes
 * - Focus management
 * - Screen reader compatibility
 */

test.describe("Accessibility — WCAG AA Audit", () => {
  test.describe("Homepage", () => {
    test.beforeEach(async ({ page }) => {
      await page.goto("/");
      await injectAxe(page);
    });

    test("should pass automated accessibility checks", async ({ page }) => {
      await checkA11y(page, undefined, {
        detailedReport: true,
        detailedReportOptions: {
          html: true,
        },
      });
    });

    test("should have proper semantic HTML structure", async ({ page }) => {
      // Check for main landmark
      const main = await page.locator("main");
      await expect(main).toBeVisible();

      // Check for header landmark
      const header = await page.locator("header");
      await expect(header).toBeVisible();

      // Check for footer landmark
      const footer = await page.locator("footer");
      await expect(footer).toBeVisible();

      // Check language attribute
      const html = page.locator("html");
      await expect(html).toHaveAttribute("lang", "fr");
    });

    test("should have accessible heading hierarchy", async ({ page }) => {
      const h1 = await page.locator("h1");
      await expect(h1).toBeVisible();
      await expect(h1).toHaveText(/Mothome/i);

      // Heading hierarchy should be proper
      const headings = await page.locator("h1, h2, h3, h4, h5, h6");
      const count = await headings.count();
      expect(count).toBeGreaterThanOrEqual(1); // At least one heading
    });

    test("should have sufficient color contrast", async ({ page }) => {
      // This is automatically checked by axe-core checkA11y above
      // Manual check for key elements
      const title = page.locator("h1");
      const titleColor = await title.evaluate((el) => {
        return window.getComputedStyle(el).color;
      });
      expect(titleColor).toBeTruthy();
    });

    test("should support keyboard navigation", async ({ page }) => {
      // Tab through interactive elements
      await page.keyboard.press("Tab");
      const focusedElement = await page.evaluate(() => {
        return document.activeElement?.tagName;
      });

      // Should focus on an interactive element
      expect(
        ["A", "BUTTON", "LINK", "INPUT", "TEXTAREA", "SELECT"].includes(
          focusedElement || ""
        )
      ).toBeTruthy();
    });

    test("should have visible focus indicators", async ({ page }) => {
      // Tab to first interactive element
      await page.keyboard.press("Tab");

      const focusedElement = await page.locator(":focus");
      const outline = await focusedElement.evaluate((el) => {
        const styles = window.getComputedStyle(el);
        return (
          styles.outline || styles.boxShadow || styles.borderColor || "none"
        );
      });

      // Focus should be visually indicated
      expect(outline).not.toBe("none");
    });

    test("should have proper button labels", async ({ page }) => {
      const buttons = await page.locator("button");
      const count = await buttons.count();

      for (let i = 0; i < count; i++) {
        const button = buttons.nth(i);
        const ariaLabel = await button.getAttribute("aria-label");
        const text = await button.textContent();

        // Button should have either aria-label or visible text
        const hasLabel = ariaLabel || (text && text.trim().length > 0);
        expect(hasLabel).toBeTruthy();
      }
    });

    test("should have proper link labels", async ({ page }) => {
      const links = await page.locator("a");
      const count = await links.count();

      for (let i = 0; i < count; i++) {
        const link = links.nth(i);
        const ariaLabel = await link.getAttribute("aria-label");
        const text = await link.textContent();
        const title = await link.getAttribute("title");

        // Link should have accessible name
        const hasAccessibleName =
          ariaLabel || (text && text.trim().length > 0) || title;
        expect(hasAccessibleName).toBeTruthy();
      }
    });

    test("should have proper form label associations", async ({ page }) => {
      const inputs = await page.locator("input, textarea, select");
      const count = await inputs.count();

      for (let i = 0; i < count; i++) {
        const input = inputs.nth(i);
        const inputId = await input.getAttribute("id");
        const ariaLabel = await input.getAttribute("aria-label");
        const ariaLabelledby = await input.getAttribute("aria-labelledby");

        if (!ariaLabel && !ariaLabelledby) {
          // If has ID, should have associated label
          if (inputId) {
            const label = await page.locator(`label[for="${inputId}"]`);
            expect(await label.count()).toBeGreaterThanOrEqual(0);
          }
        }
      }
    });

    test("should have descriptive alt text for images", async ({ page }) => {
      const images = await page.locator("img");
      const count = await images.count();

      for (let i = 0; i < count; i++) {
        const img = images.nth(i);
        const alt = await img.getAttribute("alt");
        const ariaLabel = await img.getAttribute("aria-label");
        const role = await img.getAttribute("role");

        // Image should either have alt text or be decorative
        if (role !== "presentation" && !ariaLabel) {
          expect(alt).not.toBeNull();
        }
      }
    });

    test("should have proper ARIA labels where needed", async ({ page }) => {
      // Check for aria-expanded on toggle buttons
      const toggleButtons = await page.locator('[aria-expanded]');
      const toggleCount = await toggleButtons.count();

      for (let i = 0; i < toggleCount; i++) {
        const button = toggleButtons.nth(i);
        const expanded = await button.getAttribute("aria-expanded");
        expect(["true", "false"]).toContain(expanded);
      }
    });

    test("should have skip to main content link", async ({ page }) => {
      // Check for skip link (optional but recommended)
      const skipLink = await page.locator('a[href="#main"], a[href="main"]');

      // If skip link exists, it should be keyboard accessible
      if (await skipLink.count()) {
        await expect(skipLink.first()).toBeVisible({ timeout: 100 });
      }
    });
  });

  test.describe("Mobile Accessibility", () => {
    test.use({
      viewport: { width: 375, height: 667 },
    });

    test("should pass accessibility checks on mobile", async ({ page }) => {
      await page.goto("/");
      await injectAxe(page);
      await checkA11y(page, undefined, {
        detailedReport: true,
      });
    });

    test("should have accessible mobile navigation", async ({ page }) => {
      await page.goto("/");

      // Find mobile menu button
      const menuButton = await page.locator('[aria-label*="menu" i]').first();

      if (await menuButton.count()) {
        await expect(menuButton).toHaveAttribute("aria-expanded");

        // Open menu
        await menuButton.click();

        // Menu should have proper ARIA attributes
        const menuContent = await page.locator("[aria-label*='menu' i]");
        await expect(menuContent.first()).toBeVisible();
      }
    });

    test("should have touchable tap targets (44x44px min)", async ({ page }) => {
      await page.goto("/");

      // Check button sizes
      const buttons = await page.locator("button");
      const count = await buttons.count();

      for (let i = 0; i < count; i++) {
        const button = buttons.nth(i);
        const box = await button.boundingBox();

        if (box) {
          // Buttons should be at least 44x44 pixels for touch
          expect(box.width >= 44 || box.height >= 44).toBeTruthy();
        }
      }
    });
  });

  test.describe("Keyboard Navigation", () => {
    test("should be navigable using Tab key", async ({ page }) => {
      await page.goto("/");

      // Get all focusable elements
      const focusableElements = await page.locator(
        "a, button, input, textarea, select, [tabindex]:not([tabindex='-1'])"
      );
      const count = await focusableElements.count();

      expect(count).toBeGreaterThan(0);

      // Tab through and verify focus moves
      let focusedCount = 0;
      for (let i = 0; i < count + 5; i++) {
        await page.keyboard.press("Tab");
        const focused = await page.locator(":focus");
        if (await focused.count()) {
          focusedCount++;
        }
      }

      expect(focusedCount).toBeGreaterThan(0);
    });

    test("should support Enter/Space on buttons", async ({ page }) => {
      await page.goto("/");

      const buttons = await page.locator("button").first();

      if (await buttons.count()) {
        // Focus button
        await buttons.focus();

        // Try pressing Enter
        const initialText = await buttons.textContent();
        await page.keyboard.press("Enter");

        // Button action should be triggered or no error
        expect(true).toBeTruthy();
      }
    });

    test("should have logical tab order", async ({ page }) => {
      await page.goto("/");

      // Check for negative tabindex (which breaks logical order)
      const negativeTabIndex = await page.locator("[tabindex='-1']");
      const count = await negativeTabIndex.count();

      // Negative tabindex is acceptable for hidden elements
      // Just verify it's used intentionally
      for (let i = 0; i < count; i++) {
        const element = negativeTabIndex.nth(i);
        const isVisible = await element.isVisible();
        // Elements with tabindex=-1 should typically be hidden
      }
    });
  });

  test.describe("Screen Reader Support", () => {
    test("should have descriptive page title", async ({ page }) => {
      await page.goto("/");

      const title = await page.title();
      expect(title.length).toBeGreaterThan(0);
      expect(title.toLowerCase()).toContain("mothome");
    });

    test("should have accessible landmarks", async ({ page }) => {
      await page.goto("/");

      // Check for main landmark
      const main = await page.locator("main");
      expect(await main.count()).toBeGreaterThanOrEqual(1);

      // Check for header
      const header = await page.locator("header");
      expect(await header.count()).toBeGreaterThanOrEqual(1);

      // Check for footer
      const footer = await page.locator("footer");
      expect(await footer.count()).toBeGreaterThanOrEqual(1);
    });

    test("should have proper ARIA live regions if needed", async ({ page }) => {
      await page.goto("/");

      // Check for live regions (if any dynamic content)
      const liveRegions = await page.locator(
        "[aria-live], [role='alert'], [role='status']"
      );

      // This is optional, but if present should be proper
      const count = await liveRegions.count();
      for (let i = 0; i < count; i++) {
        const region = liveRegions.nth(i);
        const ariaLive = await region.getAttribute("aria-live");
        if (ariaLive) {
          expect(["polite", "assertive", "off"]).toContain(ariaLive);
        }
      }
    });
  });

  test.describe("Footer Accessibility", () => {
    test("should have accessible footer structure", async ({ page }) => {
      await page.goto("/");
      await injectAxe(page);

      // Focus on footer section
      await checkA11y(page, "footer", {
        detailedReport: true,
      });
    });

    test("should have accessible contact information", async ({ page }) => {
      await page.goto("/");

      // Check for contact links
      const phone = await page.locator('a[href^="tel:"]');
      const email = await page.locator('a[href^="mailto:"]');

      if (await phone.count()) {
        await expect(phone.first()).toBeVisible();
      }

      if (await email.count()) {
        await expect(email.first()).toBeVisible();
      }
    });
  });

  test.describe("Header Navigation Accessibility", () => {
    test("should have accessible header structure", async ({ page }) => {
      await page.goto("/");
      await injectAxe(page);

      // Focus on header section
      await checkA11y(page, "header", {
        detailedReport: true,
      });
    });

    test("should have proper navigation labels", async ({ page }) => {
      await page.goto("/");

      // Check for navigation landmarks
      const navs = await page.locator("nav");
      const count = await navs.count();

      expect(count).toBeGreaterThan(0);

      // Each nav should have aria-label or be associated with a heading
      for (let i = 0; i < count; i++) {
        const nav = navs.nth(i);
        const ariaLabel = await nav.getAttribute("aria-label");

        if (ariaLabel) {
          expect(ariaLabel.length).toBeGreaterThan(0);
        }
      }
    });

    test("should indicate current page in navigation", async ({ page }) => {
      await page.goto("/");

      // Check for aria-current="page"
      const currentPageLink = await page.locator('[aria-current="page"]');

      // If nav exists, should have indication of current page
      if (await page.locator("nav").count()) {
        // May have aria-current or active class
        const activeLinks = await page.locator(
          'nav a[aria-current="page"], nav a.active, nav .active'
        );

        // At least one navigation indicator should exist
      }
    });
  });

  test.describe("Responsive Accessibility", () => {
    test("should maintain accessibility at tablet size", async ({ page }) => {
      // Set tablet viewport
      await page.setViewportSize({ width: 768, height: 1024 });
      await page.goto("/");
      await injectAxe(page);

      await checkA11y(page, undefined, {
        detailedReport: true,
      });
    });

    test("should maintain accessibility at desktop size", async ({ page }) => {
      // Set desktop viewport
      await page.setViewportSize({ width: 1920, height: 1080 });
      await page.goto("/");
      await injectAxe(page);

      await checkA11y(page, undefined, {
        detailedReport: true,
      });
    });
  });
});
